crash-*
# Python bytecode caches.
__pycache__/
*.pyc
# libFuzzer working dirs (regenerated every run): keep only the log_*.txt and
# summary.txt under results/, never the corpus/crash seed directories.
results/**/corpus_*/
results/**/crash_*/
# Build artifacts and cloned third-party libraries are rebuilt by scripts
# (build_*.sh) and must never be committed.
build/
libs/
# Rust cross-language backend build artifacts (rebuilt by build_rust_diff.sh).
harness/rustbridge/target/
# TFHE-rs FHE oracle build artifacts (rebuilt by build_tfhe.sh).
harness/tfhebridge/target/
# arkworks ZK oracle build artifacts (rebuilt by build_zk.sh).
harness/zkbridge/target/
